{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
  },
  "include": ["src/**/*", "frontend/src/components/ProtectedRoute.tsx", "frontend/src/Context/ToastContext.tsx"],
  "exclude": [
    "node_modules",
    "__tests__",
    "**/*.test.ts"
  ]
}